# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
# UI -> API base URL (used in src/api/telemetryClient.ts)
VITE_API_BASE_URL=http://127.0.0.1:8787

# -----------------------------------------------------------------------------
# Local API server
# -----------------------------------------------------------------------------
# API port for scripts/start-api.ts
API_PORT=8787

# Retention mode for POST /api/recommend:
# - none
# - feature_only_opt_in
# - banded_opt_in
API_RETENTION_MODE=none

# Snapshot mode for /api/snapshot and dump-lightning-snapshot script:
# - lnc  -> use real Lightning Node Connect
# - mock -> use local deterministic mock snapshot
LIGHTNING_SNAPSHOT_MODE=lnc

# -----------------------------------------------------------------------------
# Lightning Node Connect (required only when LIGHTNING_SNAPSHOT_MODE=lnc)
# -----------------------------------------------------------------------------
LNC_PAIRING_PHRASE=
LNC_PASSWORD=
LNC_NAMESPACE=tapvolt
# Optional override for LNC mailbox host/proxy
LNC_SERVER_HOST=
# Optional forwarding-history lookback window (days)
LNC_FORWARDING_RANGE_DAYS=30

# -----------------------------------------------------------------------------
# ARB / signing / verification
# -----------------------------------------------------------------------------
# Dev signing key used by build-arb/api/verify/openclaw-workflow scripts.
# IMPORTANT: change this for anything beyond local testing.
ARB_DEV_SIGNING_KEY=change-me-local-dev-key

# Optional ARB settings 
ARB_PRIVACY_POLICY_ID=feature_only
# If empty, scripts use current timestamp.
ARB_ISSUED_AT=
# Default is 86400 seconds when empty.
ARB_TTL_SECONDS=86400
# Optional fixed verification time for deterministic checks.
ARB_VERIFY_NOW=

# -----------------------------------------------------------------------------
# API released-signer enforcement (Step 30)
# -----------------------------------------------------------------------------
# Enable strict mode for POST /api/recommend.
API_REQUIRE_RELEASED_SIGNER=false

# Required when API_REQUIRE_RELEASED_SIGNER=true
API_RELEASED_SIGNER_KEY_ID=
API_RELEASED_SIGNER_KEYRING_JSON=

# Optional key provider id label in run summary.
API_RELEASED_SIGNER_KEY_PROVIDER_ID=

# Optional enclave provider mode: verified_tee | simulated_tee | local_dev | phala_cli
API_RELEASED_SIGNER_ENCLAVE_PROVIDER=verified_tee

# Optional strict policy controls.
API_RELEASED_SIGNER_MIN_EXECUTION_MODE=tee_verified
API_RELEASED_SIGNER_ALLOWED_PROVIDER_IDS=
API_RELEASED_SIGNER_ALLOWED_MEASUREMENTS=
API_RELEASED_SIGNER_ALLOWED_QUOTE_FORMATS=

# Used only when API_RELEASED_SIGNER_ENCLAVE_PROVIDER=phala_cli
API_PHALA_CVM_INFO_PATH=artifacts/phala-jupyter.cvm.json
API_PHALA_CLI_ATTEST_PATH=artifacts/phala-jupyter.attestation.cli.json
API_RELEASED_SIGNER_ENCLAVE_PROVIDER_ID=

# -----------------------------------------------------------------------------
# Phala live integration (Step 18 read-only smoke)
# -----------------------------------------------------------------------------
# Required for scripts/test-step18-phala-live-smoke.ts
PHALA_API_KEY=

# Recommended from current CLI status output:
PHALA_CLOUD_API_BASE_URL=https://cloud-api.phala.com/api/v1
PHALA_API_VERSION=2026-01-21

# Step 24 source-selected live attestation test:
# - cloud_cvm_attestation (requires PHALA_CVM_ID)
# - app_http_attestation (requires PHALA_APP_BASE_URL)
PHALA_ATTESTATION_SOURCE=cloud_cvm_attestation

# Optional for source-selected verification:
PHALA_APP_BASE_URL=
PHALA_CVM_ID=
PHALA_EXPECTED_REPORT_DATA_HEX=

# Optional Step 32 relaxations for debugging only.
# Leave false in normal use so strict recommend stays fail-closed.
API_ALLOW_APP_SOURCE_WITHOUT_COMPOSE_BINDING=false
API_ALLOW_SOURCE_WITHOUT_EXPECTED_REPORT_DATA_MATCH=false
